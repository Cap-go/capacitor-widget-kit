{
  "name": "@capgo/capacitor-widget-kit",
  "version": "8.0.0",
  "private": true,
  "description": "Capacitor plugin for generic iOS WidgetKit and Live Activities using SVG templates, declarative actions, and shared App Group persistence.",
  "main": "dist/plugin.cjs.js",
  "module": "dist/esm/index.js",
  "types": "dist/esm/index.d.ts",
  "unpkg": "dist/plugin.js",
  "files": [
    "android/src/main/",
    "android/build.gradle",
    "dist/",
    "ios/Sources",
    "ios/Tests",
    "Package.swift",
    "CapgoCapacitorWidgetKit.podspec"
  ],
  "author": "Martin Donadieu <martin@capgo.app>",
  "license": "MPL-2.0",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/Cap-go/capacitor-widget-kit.git"
  },
  "bugs": {
    "url": "https://github.com/Cap-go/capacitor-widget-kit/issues"
  },
  "homepage": "https://capgo.app/docs/plugins/widget-kit/",
  "keywords": [
    "capacitor",
    "plugin",
    "widgetkit",
    "live-activities",
    "activitykit",
    "ios"
  ],
  "scripts": {
    "verify": "bun run verify:ios && bun run verify:android && bun run verify:package",
    "verify:ios": "xcodebuild -scheme CapgoCapacitorWidgetKit -destination generic/platform=iOS",
    "verify:android": "cd android && ./gradlew clean build test && cd ..",
    "verify:package": "bun run build",
    "test:maestro": "./scripts/run-maestro-native.sh ios",
    "test:maestro:ios": "./scripts/run-maestro-native.sh ios",
    "test:maestro:android": "./scripts/run-maestro-native.sh android",
    "lint": "rimraf ./build/example-ios && bun run eslint && bun run prettier -- --check && bun run swiftlint -- lint",
    "fmt": "bun run eslint -- --fix && bun run prettier -- --write && bun run swiftlint -- --fix --format",
    "eslint": "eslint . --ext .ts",
    "prettier": "prettier-pretty-check \"**/*.{css,html,ts,js,json,java,mjs}\" --plugin=prettier-plugin-java",
    "swiftlint": "node-swiftlint",
    "docgen": "docgen --api CapgoWidgetKitPlugin --output-readme README.md --output-json dist/docs.json",
    "build": "bun run clean && bun run docgen && tsc && rollup -c rollup.config.mjs",
    "clean": "rimraf ./dist",
    "watch": "tsc --watch",
    "prepublishOnly": "bun run build",
    "check:wiring": "node scripts/check-capacitor-plugin-wiring.mjs"
  },
  "devDependencies": {
    "@capacitor/android": "^8.0.0",
    "@capacitor/cli": "^8.0.0",
    "@capacitor/core": "^8.0.0",
    "@capacitor/docgen": "^0.3.1",
    "@capacitor/ios": "^8.0.0",
    "@ionic/eslint-config": "^0.4.0",
    "@ionic/prettier-config": "^4.0.0",
    "@ionic/swiftlint-config": "^2.0.0",
    "@types/node": "^24.10.1",
    "eslint": "^8.57.1",
    "eslint-plugin-import": "^2.31.0",
    "prettier": "^3.6.2",
    "prettier-plugin-java": "^2.7.7",
    "prettier-pretty-check": "^0.2.0",
    "rimraf": "^6.1.0",
    "rollup": "^4.53.2",
    "swiftlint": "^2.0.0",
    "typescript": "^5.9.3"
  },
  "peerDependencies": {
    "@capacitor/core": ">=8.0.0"
  },
  "prettier": "@ionic/prettier-config",
  "swiftlint": "@ionic/swiftlint-config",
  "eslintConfig": {
    "extends": "@ionic/eslint-config/recommended"
  },
  "capacitor": {
    "ios": {
      "src": "ios"
    },
    "android": {
      "src": "android"
    }
  }
}
